# ============================================================
# CORAJE - Git ignore raíz
# ============================================================

# ============================================================
# Variables de entorno / secretos
# ============================================================
.env
.env.*
!*.env.example

# ============================================================
# Node / Next.js - coraje-web
# ============================================================

# Dependencies
coraje-web/node_modules/

# Yarn / PnP artifacts, por si alguna herramienta los genera accidentalmente
coraje-web/.pnp
coraje-web/.pnp.*
coraje-web/.yarn/*
!coraje-web/.yarn/patches
!coraje-web/.yarn/plugins
!coraje-web/.yarn/releases
!coraje-web/.yarn/versions

# Testing
coraje-web/coverage/

# Next.js build output
coraje-web/.next/
coraje-web/out/

# Production build output
coraje-web/build/

# Vercel
coraje-web/.vercel/

# TypeScript incremental cache
coraje-web/*.tsbuildinfo

# Prisma generated client
# Regenerar con: pnpm prisma generate
coraje-web/src/generated/prisma/

# Debug logs
coraje-web/npm-debug.log*
coraje-web/yarn-debug.log*
coraje-web/yarn-error.log*
coraje-web/pnpm-debug.log*

# ============================================================
# Logs globales
# ============================================================
*.log

# ============================================================
# Certificados / llaves
# ============================================================
*.pem
*.key
*.crt

# ============================================================
# Python
# ============================================================
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================================
# n8n / archivos sensibles y runtime local
# ============================================================
n8n/credentials/
n8n/*.credentials.json
n8n/data/
n8n/.n8n/
n8n/database.sqlite
n8n/database.sqlite-*

# ============================================================
# Backups / dumps de base de datos
# ============================================================
dumps/
backups/
*.dump
*.backup
*.sql.bak
*.sql.tmp

# ============================================================
# Sistema operativo / editores
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ============================================================
# Archivos temporales / backups
# ============================================================
*.tmp
*.temp
*.bak